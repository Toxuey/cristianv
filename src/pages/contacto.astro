---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contacto | Cristian Villamizar"
  description="Canal de contacto profesional de Cristian Villamizar para temas de gestión de instalaciones, operaciones técnicas y mejora de procesos."
  ogTitle="Contacto | Cristian Villamizar"
  ogDescription="Contacto profesional para colaboración en operaciones, gestión técnica y herramientas de control operativo."
>
  <main class="mx-auto max-w-4xl px-6 py-12 text-slate-900">
    <section class="space-y-4">
      <h1 class="text-2xl font-semibold text-slate-900">Contacto</h1>
      <p class="text-base leading-relaxed text-slate-700">
        Para temas profesionales relacionados con operaciones, facilities management y mejora de procesos,
        puedes escribir al correo:
      </p>
      <a
        href="mailto:contacto@cristianvillamizar.com"
        class="inline-block rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-800 hover:bg-slate-50"
      >
        contacto@cristianvillamizar.com
      </a>
    </section>
  </main>
</Layout>
